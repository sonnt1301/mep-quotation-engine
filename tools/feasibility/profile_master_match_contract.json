{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProfileMasterMatchContract",
  "description": "Schema for MEP Quotation Pipeline Profile Master Match Dry-run outputs",
  "type": "object",
  "properties": {
    "match_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "mode": { "type": "string", "const": "master_match_dry_run" },
    "source_write_simulation_summary": { "type": "string" },
    "ready_for_write_to_main_pipeline": { "type": "boolean", "const": false },
    "summary": {
      "type": "object",
      "properties": {
        "input_simulated_records_count": { "type": "integer", "minimum": 0 },
        "matched_count": { "type": "integer", "minimum": 0 },
        "no_match_count": { "type": "integer", "minimum": 0 },
        "possible_duplicate_count": { "type": "integer", "minimum": 0 },
        "needs_master_review_count": { "type": "integer", "minimum": 0 },
        "would_insert_count": { "type": "integer", "minimum": 0 },
        "would_update_count": { "type": "integer", "minimum": 0 },
        "would_skip_count": { "type": "integer", "minimum": 0 },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "ready_for_real_write": { "type": "boolean", "const": false },
        "ready_for_write_to_main_pipeline": { "type": "boolean", "const": false },
        "proposed_status": {
          "type": "string",
          "enum": ["MASTER_MATCH_READY_FOR_REVIEW", "BLOCKED_NEEDS_MASTER_REVIEW", "BLOCKED_NO_SIMULATION_RECORDS"]
        }
      },
      "required": [
        "input_simulated_records_count",
        "matched_count",
        "no_match_count",
        "possible_duplicate_count",
        "needs_master_review_count",
        "would_insert_count",
        "would_update_count",
        "would_skip_count",
        "blocked_count",
        "ready_for_real_write",
        "ready_for_write_to_main_pipeline",
        "proposed_status"
      ]
    },
    "match_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "match_result_id": { "type": "string" },
          "simulation_record_id": { "type": "string" },
          "write_candidate_id": { "type": "string" },
          "supplier_code": { "type": "string" },
          "material_code": { "type": "string" },
          "description": { "type": "string" },
          "unit": { "type": "string" },
          "unit_price": { "type": "integer" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "write_key": { "type": "string" },
          "simulated_result": { "type": "string" },
          "match_status": {
            "type": "string",
            "enum": ["EXACT_MATCH", "POSSIBLE_UPDATE", "POSSIBLE_DUPLICATE", "NO_MATCH", "BLOCKED"]
          },
          "recommended_action": {
            "type": "string",
            "enum": ["WOULD_INSERT", "WOULD_UPDATE", "WOULD_SKIP", "NEEDS_MASTER_REVIEW", "BLOCKED"]
          },
          "matched_master_record_id": { "type": ["string", "null"] },
          "match_confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "match_reason": { "type": "string" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ready_for_real_write": { "type": "boolean", "const": false }
        },
        "required": [
          "match_result_id",
          "simulation_record_id",
          "write_candidate_id",
          "supplier_code",
          "material_code",
          "description",
          "unit",
          "unit_price",
          "amount",
          "currency",
          "write_key",
          "simulated_result",
          "match_status",
          "recommended_action",
          "matched_master_record_id",
          "match_confidence",
          "match_reason",
          "warnings",
          "ready_for_real_write"
        ]
      }
    }
  },
  "required": [
    "match_version",
    "generated_at",
    "mode",
    "source_write_simulation_summary",
    "ready_for_write_to_main_pipeline",
    "summary",
    "match_results"
  ]
}
