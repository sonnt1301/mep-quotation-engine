{
  "$defs": {
    "WarningModel": {
      "properties": {
        "code": {
          "description": "Mã cảnh báo kỹ thuật",
          "title": "Code",
          "type": "string"
        },
        "message": {
          "description": "Nội dung chi tiết cảnh báo",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "WarningModel",
      "type": "object"
    }
  },
  "properties": {
    "created_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Thời điểm tạo PDF gốc",
      "title": "Created At"
    },
    "encrypted": {
      "default": false,
      "description": "File có bị mã hóa/đặt mật khẩu không",
      "title": "Encrypted",
      "type": "boolean"
    },
    "file_name": {
      "description": "Tên file PDF gốc",
      "title": "File Name",
      "type": "string"
    },
    "file_size": {
      "description": "Dung lượng file tính bằng bytes",
      "title": "File Size",
      "type": "integer"
    },
    "imported_at": {
      "format": "date-time",
      "title": "Imported At",
      "type": "string"
    },
    "modified_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Thời điểm chỉnh sửa PDF gốc",
      "title": "Modified At"
    },
    "page_count": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Số trang của PDF",
      "title": "Page Count"
    },
    "pdf_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Phiên bản PDF",
      "title": "Pdf Version"
    },
    "schema_version": {
      "default": "1.0",
      "description": "Phiên bản schema metadata",
      "title": "Schema Version",
      "type": "string"
    },
    "sha256": {
      "description": "Mã băm SHA256 của file",
      "title": "Sha256",
      "type": "string"
    },
    "warnings": {
      "description": "Danh sách các cảnh báo",
      "items": {
        "$ref": "#/$defs/WarningModel"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "file_name",
    "file_size",
    "sha256"
  ],
  "title": "PdfMetadataModel",
  "type": "object"
}
