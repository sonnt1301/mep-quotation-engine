{
  "$defs": {
    "EvidenceModel": {
      "properties": {
        "bbox": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Hộp bao quanh bounding box [x0, y0, x1, y1]",
          "title": "Bbox"
        },
        "crop_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Đường dẫn ảnh cắt chứa thông tin minh chứng",
          "title": "Crop Path"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Trang chứa thông tin (1-indexed)",
          "title": "Page"
        },
        "source_pdf": {
          "description": "Đường dẫn file PDF gốc chứa thông tin",
          "title": "Source Pdf",
          "type": "string"
        }
      },
      "required": [
        "source_pdf"
      ],
      "title": "EvidenceModel",
      "type": "object"
    },
    "NormalizedItemModel": {
      "properties": {
        "brand": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Thương hiệu",
          "title": "Brand"
        },
        "category": {
          "description": "Phân loại vật tư",
          "title": "Category",
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/EvidenceModel",
          "description": "Minh chứng trích xuất"
        },
        "item_id": {
          "description": "ID dòng vật tư định dạng {QUOTATION_ID}_{SEQ}",
          "title": "Item Id",
          "type": "string"
        },
        "material_code": {
          "description": "Mã vật tư chuẩn",
          "title": "Material Code",
          "type": "string"
        },
        "material_name": {
          "description": "Tên vật tư",
          "title": "Material Name",
          "type": "string"
        },
        "origin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Xuất xứ",
          "title": "Origin"
        },
        "raw_text": {
          "description": "Đoạn text gốc trích xuất từ PDF để truy vết",
          "title": "Raw Text",
          "type": "string"
        },
        "unit": {
          "description": "Đơn vị tính",
          "title": "Unit",
          "type": "string"
        },
        "unit_price": {
          "description": "Đơn giá",
          "title": "Unit Price",
          "type": "number"
        },
        "vat_rate": {
          "default": 0.1,
          "description": "Thuế suất VAT (ví dụ: 0.1 đại diện cho 10%)",
          "title": "Vat Rate",
          "type": "number"
        }
      },
      "required": [
        "item_id",
        "material_code",
        "material_name",
        "category",
        "unit",
        "unit_price",
        "raw_text",
        "evidence"
      ],
      "title": "NormalizedItemModel",
      "type": "object"
    }
  },
  "properties": {
    "currency": {
      "default": "VND",
      "description": "Đơn vị tiền tệ",
      "title": "Currency",
      "type": "string"
    },
    "items": {
      "description": "Danh sách vật tư đã chuẩn hóa",
      "items": {
        "$ref": "#/$defs/NormalizedItemModel"
      },
      "title": "Items",
      "type": "array"
    },
    "quotation_date": {
      "description": "Ngày báo giá",
      "title": "Quotation Date",
      "type": "string"
    },
    "quotation_id": {
      "description": "ID báo giá gốc",
      "title": "Quotation Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "description": "Phiên bản schema normalized",
      "title": "Schema Version",
      "type": "string"
    },
    "supplier_code": {
      "description": "Mã nhà cung cấp",
      "title": "Supplier Code",
      "type": "string"
    }
  },
  "required": [
    "quotation_id",
    "supplier_code",
    "quotation_date"
  ],
  "title": "NormalizedQuotationModel",
  "type": "object"
}
