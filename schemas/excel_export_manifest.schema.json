{
  "$defs": {
    "ExcelExportSheetModel": {
      "additionalProperties": false,
      "description": "Model chứa thông tin thống kê từng worksheet Excel.",
      "properties": {
        "name": {
          "description": "Tên worksheet",
          "title": "Name",
          "type": "string"
        },
        "row_count": {
          "description": "Số dòng dữ liệu (không tính header row)",
          "title": "Row Count",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "row_count"
      ],
      "title": "ExcelExportSheetModel",
      "type": "object"
    },
    "ParserWarningModel": {
      "description": "Model cho cảnh báo phân tích cú pháp ở cấp độ dòng hoặc manifest.",
      "properties": {
        "code": {
          "description": "Mã cảnh báo (ví dụ: low_confidence, quantity_missing)",
          "title": "Code",
          "type": "string"
        },
        "message": {
          "description": "Chi tiết nội dung cảnh báo",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ParserWarningModel",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Model manifest ghi nhận kết quả xuất bản Excel chính thức.",
  "properties": {
    "export_file": {
      "default": "exports/quotation.xlsx",
      "description": "Đường dẫn tương đối tới file Excel xuất bản",
      "title": "Export File",
      "type": "string"
    },
    "export_file_sha256": {
      "description": "SHA256 của file Excel xuất bản",
      "title": "Export File Sha256",
      "type": "string"
    },
    "exported_at": {
      "description": "Thời điểm xuất bản",
      "format": "date-time",
      "title": "Exported At",
      "type": "string"
    },
    "exporter_name": {
      "default": "openpyxl_excel_exporter",
      "description": "Tên bộ xuất bản",
      "title": "Exporter Name",
      "type": "string"
    },
    "exporter_version": {
      "default": "1.0",
      "description": "Phiên bản bộ xuất bản",
      "title": "Exporter Version",
      "type": "string"
    },
    "quotation_date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Ngày báo giá",
      "title": "Quotation Date"
    },
    "quotation_id": {
      "description": "ID báo giá gốc",
      "title": "Quotation Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "description": "Phiên bản schema export manifest",
      "title": "Schema Version",
      "type": "string"
    },
    "sheet_count": {
      "description": "Số lượng worksheets",
      "title": "Sheet Count",
      "type": "integer"
    },
    "sheets": {
      "description": "Danh sách chi tiết sheets",
      "items": {
        "$ref": "#/$defs/ExcelExportSheetModel"
      },
      "title": "Sheets",
      "type": "array"
    },
    "source_normalized": {
      "default": "normalized/normalized.json",
      "description": "Đường dẫn tương đối tới file normalized",
      "title": "Source Normalized",
      "type": "string"
    },
    "source_normalized_sha256": {
      "description": "SHA256 của file normalized",
      "title": "Source Normalized Sha256",
      "type": "string"
    },
    "supplier_code": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Mã nhà cung cấp",
      "title": "Supplier Code"
    },
    "warnings": {
      "description": "Danh sách các cảnh báo",
      "items": {
        "$ref": "#/$defs/ParserWarningModel"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "quotation_id",
    "source_normalized_sha256",
    "export_file_sha256",
    "sheet_count",
    "sheets",
    "exported_at"
  ],
  "title": "ExcelExportManifestModel",
  "type": "object"
}
